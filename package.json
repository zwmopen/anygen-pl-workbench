{
  "name": "anygen-pl-workbench",
  "version": "1.1.2",
  "description": "Local AnyGen workbench for manual, batch, and scheduled generation tasks.",
  "author": "zwmopen",
  "homepage": "https://github.com/zwmopen/anygen-pl-workbench",
  "repository": {
    "type": "git",
    "url": "https://github.com/zwmopen/anygen-pl-workbench.git"
  },
  "type": "module",
  "main": "desktop/main.mjs",
  "scripts": {
    "desktop": "electron .",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "run-scheduled": "node server.js --run-scheduled",
    "smoke-test": "node scripts/smoke-test.mjs",
    "build-client": "electron-builder --win nsis portable",
    "build-portable": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-portable-release.ps1",
    "build-installer": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-installer-release.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.anygen.workbench",
    "productName": "AnyGen Workbench",
    "asar": true,
    "asarUnpack": [
      "scripts/export-anygen-task-assets.ps1"
    ],
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "directories": {
      "output": "release-client"
    },
    "files": [
      "assets/**/*",
      "desktop/**/*",
      "public/**/*",
      "src/**/*",
      "server.js",
      "package.json",
      "scripts/export-anygen-task-assets.ps1"
    ],
    "win": {
      "icon": "assets/AnyGen-Workbench.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "AnyGen-Workbench-Installer-v${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "AnyGen-Workbench-Portable-v${version}.${ext}"
    }
  }
}
